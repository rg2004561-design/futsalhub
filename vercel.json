{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.8.0"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://futsalwebbooking.vercel.app",
    "APP_KEY": "base64:3/x1gbzGzOIl+pqjM7J/NIoUTyYzZpblhiJr6WeZGIA=",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "QUEUE_CONNECTION": "database",
    "LOG_CHANNEL": "stderr",
    "DB_CONNECTION": "mysql",
    "DB_HOST": "localhost",
    "DB_PORT": "3306",
    "DB_DATABASE": "futsalweb",
    "DB_USERNAME": "root",
    "DB_PASSWORD": "",
    "MIDTRANS_MERCHANT_ID": "",
    "MIDTRANS_CLIENT_KEY": "",
    "MIDTRANS_SERVER_KEY": "",
    "MIDTRANS_SANITIZED": "true"
  }
}
